{
  "name": "attendance",
  "version": "0.0.0",
  "scripts": {
    "test": "vitest run",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,vue}' --max-warnings 0",
    "emulator": "firebase emulators:start --only auth,firestore",
    "dev:full": "concurrently -k -n emulator,vite -c blue,green \"npm run emulator\" \"npm run dev\"",
    "deploy": "firebase deploy --only firestore:rules,firestore:indexes,hosting",
    "test:rules": "vitest --config vitest.rules.config.ts run"
  },
  "type": "module",
  "private": true,
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^11.3.0",
    "dompurify": "^3.4.10",
    "firebase": "^11.10.0",
    "pinia": "^2.3.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.38",
    "vue-router": "^4.6.4",
    "vuetify": "^4.1.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/node": "^22.19.21",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "firebase-tools": "^13.35.1",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.2.12"
  }
}
